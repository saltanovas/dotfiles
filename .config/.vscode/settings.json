{
  "update.mode": "manual",
  "window.titleBarStyle": "custom",
  "workbench.startupEditor": "newUntitledFile",
  "workbench.editorAssociations": {
    "*.plist": "binaryPlistEditor.edit"
  },
  "workbench.activityBar.location": "top",
  "workbench.sideBar.location": "left",
  "workbench.tree.indent": 19,
  "workbench.tree.renderIndentGuides": "always",
  "explorer.autoReveal": false, // Navigates to the file in the explorer when opened
  "explorer.compactFolders": false,
  "breadcrumbs.enabled": false,

  "editor.minimap.enabled": false,
  "editor.overviewRulerBorder": false, // Border on the scrollbar
  "editor.scrollbar.horizontal": "hidden",
  "editor.smoothScrolling": true,
  "editor.stickyScroll.enabled": true,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",

  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontSize": 14,
  "editor.tabSize": 4,
  "editor.lineHeight": 24,
  "editor.lineDecorationsWidth": 0, // Width between line numbers and code
  "editor.detectIndentation": false,
  "editor.insertSpaces": true, // Use spaces as indentation characters instead of tabs
  "editor.renderControlCharacters": true,
  "editor.renderFinalNewline": "on",
  "editor.fontLigatures": false, // e.g. != is shown as ≠
  "editor.semanticHighlighting.enabled": true,
  "editor.bracketPairColorization.enabled": false,
  "editor.matchBrackets": "near",
  "editor.foldingHighlight": false, // Highlight the folded code

  // Formatters
  "editor.formatOnPaste": false,
  "editor.formatOnSave": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[c][cpp]": { "editor.defaultFormatter": "ms-vscode.cpptools" },
  "[go]": { "editor.defaultFormatter": "golang.go" },
  "[java]": { "editor.defaultFormatter": "redhat.java" },
  "[php]": { "editor.defaultFormatter": "bmewburn.vscode-intelephense-client" },
  "[xml]": { "editor.defaultFormatter": "redhat.vscode-xml" },
  "[toml]": { "editor.defaultFormatter": "tamasfe.even-better-toml" },
  "[shellscript]": { "editor.defaultFormatter": "lumirelle.shell-format-rev" },

  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 12,

  "workbench.iconTheme": "vscode-jetbrains-icon-theme-2023-dark",
  "workbench.colorTheme": "Aivaras Darcula IntelliJ",
  "workbench.colorCustomizations": {},
  "editor.tokenColorCustomizations": {
    "textMateRules": []
  }
}
